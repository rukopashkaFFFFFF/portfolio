# Backend variables
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"
JWT_SECRET="change-this-to-a-random-secret"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
UPLOAD_DIR="../uploads"
MAX_UPLOAD_SIZE=52428800

# Backend port
PORT=4000

# Vite dev server origin (for CORS)
CORS_ORIGIN="http://localhost:5173"

# Frontend (for production build, the API goes here)
VITE_API_BASE="http://localhost:4000/api"
